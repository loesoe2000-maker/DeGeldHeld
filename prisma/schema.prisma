// DeGeldHeld — Prisma schema
// Run: pnpm prisma:generate && pnpm prisma:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----- NextAuth core models -----

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // v7 referrals — eigen referral-code voor delen; null tot eerste share
  referralCode  String?   @unique

  // v8 GDPR + email prefs
  notificationsEnabled Boolean  @default(true)
  deletedAt            DateTime?
  ocrTrainingOptIn     Boolean  @default(false)

  // v11 anti-fraud: account suspend door admin na review.
  // Suspended users kunnen inloggen maar geen nieuwe uploads doen.
  suspendedAt          DateTime?
  suspendedReason      String?

  // v13 subscription plan — optioneel maandabonnement (€4,99/mnd)
  // als alternatief voor de no-cure-no-pay fee. status:
  //   null      → no subscription, fee per verified saving
  //   "active"  → unlimited negotiations included
  //   "past_due"/"canceled" → fee-flow resumes
  subscriptionStatus String?
  subscriptionPlan   String?
  subscriptionRenewsAt DateTime?

  // app data
  accounts      Account[]
  sessions      Session[]
  bills         Bill[]
  negotiations  Negotiation[]
  payments      Payment[]
  waitlistEntry WaitlistEntry?
  referralsCreated Referral[] @relation("ReferralOwner")
  bankConnections  BankConnection[]
  detectedRecurring DetectedRecurring[]
  fraudFlags    FraudFlag[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----- App models -----

enum BillCategory {
  TELECOM
  ENERGIE
  WATER
  GEMEENTE
  VERZEKERING
  HYPOTHEEK
  BANK
  ABONNEMENT
  STREAMING
  GYM
  OV
  SOFTWARE
  OPSLAG
  OVERIG
}

enum NegotiationState {
  NIEUW
  BILL_UPLOAD
  ANALYSE
  EMAIL_GEN
  AWAITING
  // v5 multi-round:
  EMAIL_SENT
  RESPONSE_RECEIVED
  COUNTER_SENT
  ACCEPTED
  REJECTED
  // legacy terminals (still used by older negotiations):
  SUCCESS
  FAILED
  BILLED
  // v11 revenue verification:
  SUCCESS_UNVERIFIED       // user claims success without uploading proof
  BILLED_PENDING_PAYMENT   // proof verified, fee invoice waiting on user
  BILLED_OVERDUE           // 14 days passed without payment
}

enum RoundOutcome {
  PENDING
  ACCEPTED
  REJECTED
  ESCALATED
  // v10 auto-pingpong: AI has drafted a counter-mail; user must
  // confirm before it is sent via Resend.
  AWAITING_USER_CONFIRM
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

model Bill {
  id           String       @id @default(cuid())
  // v15: userId is nullable so anonymous visitors can upload before
  // they sign up. Anonymous bills carry an anonymousSessionId cookie
  // value; on magic-link signup the bills are claimed (userId set,
  // anonymousSessionId cleared, claimedAt stamped).
  userId       String?
  anonymousSessionId String?
  // v15.1: cross-browser claim fix — when a visitor submits the
  // email-prompt, we stamp this column on every bill in their
  // anonymous session. The magic-link callback then claims by
  // email match in addition to the cookie, so the link can open
  // in a different browser than the upload happened in.
  anonymousEmail String?
  claimedAt    DateTime?
  provider     String
  category     BillCategory @default(OVERIG)
  amountCents  Int
  // v3.1: split maand-abonnement vs factuur-totaal voor accurate
  // markt-vergelijking. Beide optional voor backwards-compat met
  // bills die voor de migratie zijn aangemaakt.
  monthlyCents Int?
  totalCents   Int?
  plan         String?
  period       String?
  // v3.1: gepar­seerde factuur-periode (1e van de maand UTC).
  // Voor stale-warning op /onderhandel/analyse (>180 dagen oud).
  invoiceDate  DateTime?
  // v4: klantnummer uit OCR — gebruikt in onderhandel-email zodat retentie
  // direct kan zoeken op account.
  customerNumber String?
  // v5: country detected by OCR (NL/BE/DE/FR/UK/US/ES/IT/INT). Used to
  // disambiguate providers and to drive locale + dynamic alternatives.
  country      String?
  // v10 categories-v2: sub-type binnen primaire category (string voor
  // flexibiliteit, geen enum). Bv "stroom+gas", "mobiel", "auto".
  subType      String?
  // v5: currency from valuta-symbol / IBAN-prefix. Default EUR for NL/EU.
  currency     String       @default("EUR")
  // v17: category-specific OCR fields, persisted so the analyse-page
  // can compare against the user's REAL invoice instead of hardcoded
  // market medians. All nullable — only filled when OCR was confident.
  energyKwhRateCents       Int?
  energyM3RateCents        Int?
  energyContractType       String?   // vast/variabel/dynamisch/unknown
  insuranceCoverage        String?   // WA/WA+/CASCO/UNKNOWN
  insuranceDeductibleCents Int?
  mortgageInterestPct      Float?
  mortgageTermYears        Int?
  bankAccountTier          String?
  streamingTier            String?
  imageHash    String?      @unique
  rawOcr       String?      @db.Text
  createdAt    DateTime     @default(now())

  // v6 paywall: position is the 0-indexed rank within this user's bills
  // (first upload = 0 → free, second onwards → paywall). paidAt is set
  // by the /api/webhooks/stripe handler when checkout.session.completed.
  position     Int          @default(0)
  paidAt       DateTime?

  // v8 monthly re-check
  lastRecheckAt    DateTime?
  nextRecheckAt    DateTime?
  lastRecheckMailAt DateTime?
  deletedAt        DateTime?

  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  negotiation  Negotiation?

  @@index([userId])
  @@index([imageHash])
  @@index([userId, createdAt])
  @@index([anonymousSessionId])
  @@index([anonymousEmail])
}

model Negotiation {
  id              String           @id @default(cuid())
  userId          String
  billId          String           @unique
  state           NegotiationState @default(NIEUW)
  emailSubject    String?
  emailBody       String?          @db.Text
  strategy        String?
  expectedSavingsCents Int?
  actualSavingsCents   Int?
  confidence      Float?
  reasoning       String?          @db.Text
  followUpAt      DateTime?
  emailSentAt     DateTime?
  outcomeAskedAt  DateTime?
  closedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // v7 feedback loop — does the AI mail actually work?
  userRating          Int?      // -1 thumbs-down / 0 neutraal / 1 thumbs-up
  mailUsed            Boolean   @default(false)  // user kopieerde/verstuurde
  providerResponded   Boolean?  // user gaf aan dat provider antwoordde

  // v10 auto-pingpong: email thread tracking voor inbound matching.
  // Resend webhook gebruikt In-Reply-To header om binnenkomende mail
  // aan deze negotiation te koppelen.
  providerThreadId String? @unique

  // v11 revenue verification: user moet bewijs leveren voordat
  // actualSavingsCents als verified telt en de fee getriggerd wordt.
  proofRequired    Boolean   @default(true)
  proofVerifiedAt  DateTime?
  feeInvoicedAt    DateTime?
  feeAmountCents   Int?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bill    Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  payment Payment?
  rounds  NegotiationRound[]
  whatsappThread WhatsAppThread?
  proofs  OutcomeProof[]

  @@index([userId])
  @@index([state])
  @@index([followUpAt])
  // v6 perf: powers the cron follow-up + dashboard "still-waiting" query.
  @@index([state, emailSentAt])
}

// v8 WhatsApp tracking (provider conversation via Twilio/360dialog)
model WhatsAppThread {
  id              String   @id @default(cuid())
  negotiationId   String   @unique
  providerNumber  String
  ourNumber       String
  userPhoneNumber String?
  status          String   @default("active")
  createdAt       DateTime @default(now())

  negotiation Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  messages    WhatsAppMessage[]

  @@index([providerNumber])
}

model WhatsAppMessage {
  id              String   @id @default(cuid())
  threadId        String
  direction       String              // "inbound" | "outbound"
  body            String   @db.Text
  mediaUrl        String?
  // AI counter-draft awaiting user confirm. False = real message sent/received.
  pendingApproval Boolean  @default(false)
  receivedAt      DateTime @default(now())

  thread WhatsAppThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model NegotiationRound {
  id               String       @id @default(cuid())
  negotiationId    String
  roundNumber      Int
  providerResponse String?      @db.Text
  responseOcrText  String?      @db.Text
  analysisJson     String?      @db.Text
  offeredCents     Int?
  counterSubject   String?
  counterBody      String?      @db.Text
  outcome          RoundOutcome @default(PENDING)
  // v10 auto-pingpong: optional inbound-Resend metadata + confirm-send
  // bookkeeping. confirmedSentAt is set when the user clicks "Verstuur
  // counter via DeGeldHeld" en de mail daadwerkelijk via Resend gaat.
  inboundMessageId String?
  inboundReplyTo   String?
  confirmedSentAt  DateTime?
  createdAt        DateTime     @default(now())

  negotiation Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@unique([negotiationId, roundNumber])
  @@index([negotiationId])
}

// v11 anti-fraud: scored flag van een suspicieus account. Admin
// review-panel toont openstaande flags, kan unflag of suspend.
model FraudFlag {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  reasons   String   @db.Text
  resolved  Boolean  @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resolved, createdAt])
}

// v11 revenue verification: bewijsstuk dat de user daadwerkelijk
// bespaard heeft. Zonder verified proof: state = SUCCESS_UNVERIFIED,
// telt niet mee voor /proof aggregates en triggert geen fee.
model OutcomeProof {
  id                 String    @id @default(cuid())
  negotiationId      String
  kind               String    // "forwarded_email" | "new_bill" | "screenshot" | "manual"
  storageUrl         String?
  parsedAmountCents  Int?
  verifiedAt         DateTime?
  verificationStatus String    @default("pending") // pending | verified | rejected | manual_review
  verifierNote       String?   @db.Text
  createdAt          DateTime  @default(now())

  negotiation Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@index([negotiationId])
  @@index([verificationStatus])
}

model Payment {
  id                  String        @id @default(cuid())
  userId              String
  negotiationId       String        @unique
  stripeSessionId     String?       @unique
  stripePaymentId     String?
  amountCents         Int
  status              PaymentStatus @default(PENDING)
  refundedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  negotiation Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  userId    String?  @unique
  source    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
}

// v8 OCR fine-tune dataset
model OcrTrainingSample {
  id              String   @id @default(cuid())
  userId          String?
  imageStorageUrl String?              // Vercel Blob URL (null = text-only)
  anonymizedJson  String   @db.Text    // ground-truth labels, PII-stripped
  reviewed        Boolean  @default(false)
  reviewerUserId  String?
  billCategory    String
  country         String
  createdAt       DateTime @default(now())

  @@index([reviewed])
  @@index([billCategory])
}

// v9 cron-lock — prevent duplicate runs (Vercel can fire same cron twice
// during rolling deploys; one wins via unique(jobName,runDate)).
model CronRunLog {
  id             String    @id @default(cuid())
  jobName        String                 // 'outcome-followup' | 'monthly-recheck' | 'psd2-sync' | 'follow-up'
  runDate        String                 // YYYY-MM-DD (UTC)
  status         String    @default("running")  // running | done | failed
  itemsProcessed Int       @default(0)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@unique([jobName, runDate])
  @@index([jobName, startedAt])
}

model MarketProvider {
  id         String       @id @default(cuid())
  name       String       @unique
  category   BillCategory
  // Tarief per maand in cents voor instap-pakket (laagste plan).
  basePriceCents Int
  url        String?
  notes      String?
  updatedAt  DateTime     @updatedAt

  plans MarketPlan[]

  @@index([category])
}

enum CandidateStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProviderCandidate {
  id            String          @id @default(cuid())
  name          String
  country       String
  retentionJson String          @db.Text
  status        CandidateStatus @default(PENDING)
  source        String?         // bv "user_upload" / "admin"
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([name, country])
  @@index([status])
}

// v8 PSD2 — bank-connection via Tink Open Banking
model BankConnection {
  id              String    @id @default(cuid())
  userId          String
  bankName        String
  accessTokenEnc  String    @db.Text
  refreshTokenEnc String?   @db.Text
  expiresAt       DateTime
  lastSyncAt      DateTime?
  status          String    @default("active")  // active | revoked | expired
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Detected recurring debit not yet converted to a Bill — shown on /account/banks
model DetectedRecurring {
  id              String    @id @default(cuid())
  userId          String
  bankConnectionId String?
  counterpartyName String
  monthlyCents    Int
  category        String    @default("OVERIG")
  lastSeenAt      DateTime
  occurrences     Int       @default(2)
  convertedBillId String?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, convertedBillId])
}

model Referral {
  id          String    @id @default(cuid())
  code        String    @unique          // 6-letter slug
  ownerId     String
  usedById    String?
  usedAt      DateTime?
  rewardCents Int?
  createdAt   DateTime  @default(now())

  owner User @relation("ReferralOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([code])
}

model MarketPlan {
  id          String       @id @default(cuid())
  providerId  String
  name        String
  category    BillCategory
  priceCents  Int
  features    String?      @db.Text
  updatedAt   DateTime     @updatedAt

  provider MarketProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([category, priceCents])
}
