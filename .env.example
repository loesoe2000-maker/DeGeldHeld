## DeGeldHeld env (kopieer naar .env.local en vul in)

# --- Database ---
# Vercel Postgres connection string. Pooler URL voor app, direct URL voor migrations.
DATABASE_URL="postgresql://user:pass@host:5432/degeldheld?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/degeldheld?sslmode=require"

# --- NextAuth ---
NEXTAUTH_SECRET="generate-via-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- Resend (magic link + transactional email) ---
RESEND_API_KEY="re_xxx"
EMAIL_FROM="DeGeldHeld <hallo@degeldheld.com>"

# --- Groq (LLM voor OCR + email gen) ---
GROQ_API_KEY="gsk_xxx"
GROQ_VISION_MODEL="llama-3.2-90b-vision-preview"
GROQ_TEXT_MODEL="llama-3.1-70b-versatile"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# --- Sentry ---
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# --- App ---
APP_URL="http://localhost:3000"
APP_NAME="DeGeldHeld"
