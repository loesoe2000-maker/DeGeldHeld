{
  "name": "degeldheld",
  "version": "0.1.0",
  "private": true,
  "description": "DeGeldHeld — automatisch onderhandelen op Nederlandse maandlasten via AI",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run tests/round-analysis-golden.test.ts",
    "test:integration": "vitest --config vitest.integration.config.ts run",
    "test:e2e": "playwright test",
    "smoke": "tsx scripts/smoke_test.ts",
    "smoke:prod": "tsx scripts/smoke-prod.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx scripts/seed.ts",
    "update-prices": "tsx scripts/update_prices.ts",
    "rotate-keys": "tsx scripts/rotate-keys.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@napi-rs/canvas": "^1.0.0",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^8.45.0",
    "@vercel/analytics": "^2.0.1",
    "groq-sdk": "^0.9.1",
    "next": "14.2.18",
    "next-auth": "5.0.0-beta.25",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "stripe": "^17.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "14.2.18",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
